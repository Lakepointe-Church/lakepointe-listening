# ── Neon serverless Postgres ────────────────────────────────────────────────
# Slice 1 creates the `mention` + `poll_run` schema against this DB.
DATABASE_URL=

# ── Cron / manual-refresh auth ──────────────────────────────────────────────
# Vercel sends `Authorization: Bearer $CRON_SECRET` to the cron route
# automatically. The manual "Refresh now" button uses the same guard.
CRON_SECRET=

# ── Reddit (Slice 3) — OAuth2 client-credentials "script" app ───────────────
# User-Agent is built as: web:lakepointe-listening:v1.0 (by /u/REDDIT_USERNAME)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# ── YouTube Data API v3 (Slice 4) ───────────────────────────────────────────
YOUTUBE_API_KEY=

# ── Google Programmable Search / CSE (Slice 5) ──────────────────────────────
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
