# ── Neon serverless Postgres ────────────────────────────────────────────────
# Slice 1 creates the `mention` + `poll_run` schema against this DB.
DATABASE_URL=

# ── Cron / manual-refresh auth ──────────────────────────────────────────────
# Vercel sends `Authorization: Bearer $CRON_SECRET` to the cron route
# automatically. The manual "Refresh now" button uses the same guard.
CRON_SECRET=

# ── YouTube Data API v3 (Slice 4) ───────────────────────────────────────────
# `listening-dashboard` key, Google Cloud project `lakepointe-social-dashboard`.
YOUTUBE_API_KEY=

# No Reddit credentials, no Google CSE key/cx — Reddit is polled via public
# search.rss (no auth) and Google CSE was dropped (closed to new projects).
